# ==============================================================================
# BACKEND .gitignore — Node.js / Express (ESM)
# ==============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Client data — NEVER commit Excel files ────────────────────────────────────
# The entire data/ folder contains confidential client data
data/
*.xls
*.xlsx
*.xlsm
*.xlsb

# ── Debug artefacts (generated during development) ────────────────────────────
debug_headers.txt
debug_processed_rows.json

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# ── Misc ──────────────────────────────────────────────────────────────────────
*.local
