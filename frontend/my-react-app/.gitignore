# ==============================================================================
# FRONTEND .gitignore — React + TypeScript + Vite
# ==============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── TypeScript build cache ─────────────────────────────────────────────────────
*.tsbuildinfo

# ── Vite cache ────────────────────────────────────────────────────────────────
.vite/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ──────────────────────────────────────────────────────────────────────
*.local
